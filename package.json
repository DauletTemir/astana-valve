{
  "name": "astana-valve-website",
  "version": "1.0.0",
  "description": "Astana Valve — Multilingual B2B website with Playwright tests",
  "scripts": {
    "test": "playwright test",
    "test:smoke": "playwright test tests/smoke/",
    "test:functional": "playwright test tests/functional/",
    "test:headed": "playwright test --headed",
    "test:report": "playwright show-report",
    "serve": "npx http-server . -p 3000 -o",
    "lint:html": "node tests/utils/html-validator.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^20.19.41",
    "http-server": "^14.1.1",
    "puppeteer": "^25.0.4"
  },
  "keywords": [
    "valve",
    "industrial",
    "b2b",
    "multilingual",
    "kazakhstan"
  ],
  "author": "Astana Valve Development Team",
  "license": "UNLICENSED"
}
