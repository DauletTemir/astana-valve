# ╔══════════════════════════════════════════════╗
# ║  Astana Valve — .gitignore                   ║
# ║  Stack: Node.js · TypeScript · Playwright    ║
# ╚══════════════════════════════════════════════╝

# ── Зависимости ──────────────────────────────────
node_modules/
jspm_packages/
.pnpm-store/
.yarn/
.pnp.*

# ── TypeScript ────────────────────────────────────
*.tsbuildinfo
dist/
out/

# ── Playwright: тесты и отчёты ───────────────────
test-results/
playwright-report/
blob-report/

# ── WebP изображения ──────────────────────────────
# WebP коммитим — нужны для GitHub Pages (без них <source type="image/webp"> даёт 404)
# img/**/*.webp

# ── ZIP-архив каталога (генерируется из PDF) ─────
products-catalog.zip

# ── Логи ─────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
pids/
*.pid
*.pid.lock

# ── Переменные окружения (секреты!) ──────────────
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
credentials.json
service-account.json

# ── Нативные аддоны Node.js ───────────────────────
*.node
build/Release/

# ── Кэши инструментов ────────────────────────────
.npm/
.eslintcache
.stylelintcache
.cache/
.parcel-cache/
.vite/

# ── Покрытие тестами ─────────────────────────────
coverage/
*.lcov
.nyc_output/

# ── Системные файлы macOS / Windows ──────────────
.DS_Store
**/.DS_Store
Thumbs.db
Desktop.ini
*.lnk

# ── Редакторы ─────────────────────────────────────
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo
*~

# ── Временные и резервные файлы ───────────────────
*.tmp
*.bak
*.orig

# ── Диагностические отчёты Node.js ───────────────
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# ── Python ────────────────────────────────────────
.venv/
venv/
ENV/
env/
__pycache__/
*.py[cod]
*.pyo
